{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "declaration": true,
        "declarationDir": "./ts-types",
        "emitDeclarationOnly": true,
        "erasableSyntaxOnly": true,
        "module": "nodenext",
        "outDir": ".",
        "rewriteRelativeImportExtensions": true,
        "rootDir": ".",
        "strict": true,
        "target": "esnext",
        "typeRoots": [
            "./node_modules/@types"
        ],
        "types": ["node"],
        "useDefineForClassFields": true,
        "verbatimModuleSyntax": true
    },
    "exclude": [
        "./index.ts",
        "./lib/**/*",
        "./tests/**/*",
        "./ts-types/**/*"
    ]
}